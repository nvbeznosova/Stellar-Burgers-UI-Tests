{
    // Автосохранение исправлений по форматированию
    "editor.codeActionsOnSave": [
        "source.organizeImports",
        "source.fixAll"
    ],

    // Размер табуляции
    "editor.tabSize": 4,

    // Пути, где Python будет искать модули (чтобы VSCode видел locators и другие пакеты)
    "python.analysis.extraPaths": [
        "./Sprint_5"
    ],

    // Использовать интерпретатор виртуального окружения проекта
    "python.pythonPath": ".venv/bin/python",

    // Настройки линтера
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": true,
    "python.linting.flake8Enabled": true,

    // Форматирование кода
    "python.formatting.provider": "black",

    // Настройки pytest
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        "Sprint_5/tests"
    ]
}
